# JARVIS - Environment Configuration
# Copy this file to .env and fill in your values

# ==========================================
# CORE SETTINGS
# ==========================================
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=jarvis-development-key-change-in-production

# ==========================================
# SERVER SETTINGS
# ==========================================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# ==========================================
# DATABASE
# ==========================================
DATABASE_URL=postgresql://jarvis:jarvis_password@db:5432/jarvis
DATABASE_POOL_SIZE=10
DATABASE_POOL_MAX_OVERFLOW=20

# ==========================================
# REDIS
# ==========================================
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_TTL=3600

# ==========================================
# ENCRYPTION (GENERATED - DO NOT SHARE!)
# ==========================================
ENCRYPTION_KEY=gAAAAABlsK5Z-5eXz9K7q8Q9pL2mN3oR4sT5uV6wX7yZ8aB9cD0eF1gH2iJ3kL4mN5oP6qR7sT8uV9wX0yZ1aB2cD3eF4gH5iJ6kL7mN8oP9qR0sT1uV2wX3yZ4aB5cD6eF7gH8iJ9kL0mN1oP2qR3sT4uV5wX6yZ7aB8cD9eF0gH1iJ2kL3mN4oP5qR6sT7uV8wX9yZ0aB0cD0eF0gH0iJ0kL0mN0oP0qR0sT0uV0wX0yZ0aB0cD0
JWT_SECRET_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiJqYXJ2aXMiLCJpYXQiOjE2ODk2MDAwMDB9.jarvis_jwt_secret_key_development
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ==========================================
# LLM / OLLAMA
# ==========================================
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=mistral:latest
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048
LLM_CONTEXT_WINDOW=4096

# ==========================================
# EMAIL INTEGRATION - MICROSOFT/OUTLOOK
# ==========================================
EMAIL_PROVIDER=microsoft
EMAIL_ADDRESS=ra@race-engineering.de
EMAIL_TENANT_ID=
EMAIL_CLIENT_ID=
EMAIL_CLIENT_SECRET=
EMAIL_CHECK_INTERVAL=300

# Office 365 Direct Connection (Standard Password)
OFFICE365_SMTP_HOST=smtp.office365.com
OFFICE365_SMTP_PORT=587
OFFICE365_IMAP_HOST=imap.office365.com
OFFICE365_IMAP_PORT=993
OFFICE365_APP_PASSWORD=LeAn12rr

# ==========================================
# INSTAGRAM INTEGRATION
# ==========================================
INSTAGRAM_BUSINESS_ACCOUNT_ID=
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_GRAPH_API_VERSION=v18.0

# ==========================================
# WHATSAPP BUSINESS INTEGRATION
# ==========================================
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v18.0
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# ==========================================
# LINKEDIN INTEGRATION
# ==========================================
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_ORGANIZATION_ID=

# ==========================================
# CONTENT GENERATION
# ==========================================
DAILY_CONTENT_MIN=1
DAILY_CONTENT_MAX=3
CONTENT_GENERATION_SCHEDULE=09:00,13:00,18:00

# ==========================================
# LOGGING
# ==========================================
LOG_LEVEL=INFO
LOG_FILE=logs/jarvis.log
LOG_FORMAT=json

# ==========================================
# SECURITY
# ==========================================
ALLOWED_IPS=127.0.0.1,localhost
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600
ENABLE_API_DOCS=true

# ==========================================
# FEATURES (Toggle)
# ==========================================
FEATURE_EMAIL=true
FEATURE_INSTAGRAM=false
FEATURE_WHATSAPP=false
FEATURE_LINKEDIN=false
FEATURE_CODE_GENERATION=false
FEATURE_VIDEO_GENERATION=false
