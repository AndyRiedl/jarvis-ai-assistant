# JARVIS - Environment Configuration
# Copy this file to .env and fill in your values

# ==========================================
# CORE SETTINGS
# ==========================================
ENVIRONMENT=development
DEBUG=false
SECRET_KEY=your-secret-key-change-this-in-production

# ==========================================
# SERVER SETTINGS
# ==========================================
API_HOST=localhost
API_PORT=8000
API_WORKERS=4
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# ==========================================
# DATABASE
# ==========================================
DATABASE_URL=postgresql://jarvis:jarvis_password@db:5432/jarvis
DATABASE_POOL_SIZE=10
DATABASE_POOL_MAX_OVERFLOW=20

# ==========================================
# REDIS
# ==========================================
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_TTL=3600

# ==========================================
# ENCRYPTION (CRITICAL - CHANGE THESE!)
# ==========================================
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-generated-encryption-key-here
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ==========================================
# LLM / OLLAMA
# ==========================================
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=mistral:latest
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048
LLM_CONTEXT_WINDOW=4096

# ==========================================
# EMAIL INTEGRATION - MICROSOFT/OUTLOOK
# ==========================================
EMAIL_PROVIDER=microsoft
EMAIL_ADDRESS=your-email@company.onmicrosoft.com
EMAIL_TENANT_ID=your-tenant-id
EMAIL_CLIENT_ID=your-client-id
EMAIL_CLIENT_SECRET=your-client-secret
EMAIL_CHECK_INTERVAL=300  # seconds

# Alternative: Office 365 Direct Connection
OFFICE365_SMTP_HOST=smtp.office365.com
OFFICE365_SMTP_PORT=587
OFFICE365_IMAP_HOST=imap.office365.com
OFFICE365_IMAP_PORT=993
OFFICE365_APP_PASSWORD=your-app-password

# ==========================================
# INSTAGRAM INTEGRATION
# ==========================================
INSTAGRAM_BUSINESS_ACCOUNT_ID=your-account-id
INSTAGRAM_ACCESS_TOKEN=your-long-lived-access-token
INSTAGRAM_GRAPH_API_VERSION=v18.0

# ==========================================
# WHATSAPP BUSINESS INTEGRATION
# ==========================================
WHATSAPP_BUSINESS_ACCOUNT_ID=your-account-id
WHATSAPP_ACCESS_TOKEN=your-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_API_VERSION=v18.0
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token

# ==========================================
# LINKEDIN INTEGRATION
# ==========================================
LINKEDIN_CLIENT_ID=your-client-id
LINKEDIN_CLIENT_SECRET=your-client-secret
LINKEDIN_ACCESS_TOKEN=your-access-token
LINKEDIN_ORGANIZATION_ID=your-organization-id

# ==========================================
# CONTENT GENERATION
# ==========================================
# Min/Max content suggestions per day
DAILY_CONTENT_MIN=1
DAILY_CONTENT_MAX=3
CONTENT_GENERATION_SCHEDULE=09:00,13:00,18:00  # UTC

# ==========================================
# LOGGING
# ==========================================
LOG_LEVEL=INFO
LOG_FILE=logs/jarvis.log
LOG_FORMAT=json

# ==========================================
# SECURITY
# ==========================================
ALLOWED_IPS=["127.0.0.1","localhost"]
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600
ENABLE_API_DOCS=true  # Set to false in production

# ==========================================
# FEATURES (Toggle)
# ==========================================
FEATURE_EMAIL=true
FEATURE_INSTAGRAM=true
FEATURE_WHATSAPP=true
FEATURE_LINKEDIN=true
FEATURE_CODE_GENERATION=false  # Phase 2
FEATURE_VIDEO_GENERATION=false # Phase 2
